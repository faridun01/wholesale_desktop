{
  "name": "wholesale-crm",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "author": "Your Name",
  "description": "Wholesale CRM Desktop Application",
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:backend && npm run build:frontend",
    "lint": "tsc -p backend --noEmit && tsc -p frontend --noEmit",
    "prisma:generate": "prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=backend/prisma/schema.prisma",
    "electron:dev": "concurrently -k --success first \"npm run dev:frontend\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.1",
    "prisma": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.1click.sklad",
    "productName": "1Click: Склад",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "backend/dist/**/*",
      "backend/.env",
      "backend/prisma/prod.db",
      "backend/prisma/schema.prisma",
      "backend/package.json",
      "frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "backend/.env",
      "backend/dist/**",
      "backend/prisma/prod.db",
      "node_modules/.prisma/**",
      "node_modules/@prisma/client/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "1Click: Склад",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
